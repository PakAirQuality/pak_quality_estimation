# Example environment configuration. Copy to `.env` and fill in your own values.
# No secrets are committed to this repository; all credentials and infrastructure
# identifiers are supplied at runtime via environment variables.

# --- Google Cloud Storage (object store for inputs, feature store, outputs) ---
# Provide your own GCS buckets / project; defaults in code are neutral placeholders.
GCP_PROJECT=your-gcp-project
PAQI_RAW_BUCKET=gs://your-raw-bucket
PAQI_DERIVED_BUCKET=your-derived-bucket
PAQI_LAKE_PATH=gs://your-bucket/master_training/master
PAQI_GEOSCF_PATTERN=gs://your-raw-bucket/raw/geos_cf_pakistan_2020_2025/PM25/geos_cf_pm25_pakistan_{date}.tif

# --- Input data-source credentials (for ingestion only) ---
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
CDS_API_KEY=
# Google Earth Engine uses its own `earthengine authenticate` flow.
